      "Bash(powershell -Command \"Stop-Process -Id \\(Get-NetTCPConnection -LocalPort 3001 -ErrorAction SilentlyContinue | Select-Object -ExpandProperty OwningProcess -Unique\\) -Force -ErrorAction SilentlyContinue\")",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:56502/)"
    ]
  }
}
