{
  "permissions": {
    "allow": [
      "Bash(where npm:*)",
      "Bash(where node:*)",
      "Bash(where npx:*)",
      "Bash(where powershell:*)",
      "Bash(where php:*)",
      "Bash(where ruby:*)",
      "Bash(where dotnet:*)",
      "Bash(dotnet --version)",
      "Bash(powershell -Command \"Get-Command npm,node,npx -ErrorAction SilentlyContinue | Select-Object Name,Source\")",
